{
    "data": {
      "train_data_path": "./datasets/tofu/subset.jsonl",
      "test_data_path": "./datasets/tofu/test.jsonl"
    },
    "influence": {
      "outdir": "output_dir",
      "seed": 42,
      "cal_words_infl": false,
      "n_threads": 1,
      "RapidGrad": {
        "enable": true,
        "RapidGrad_K": 65536,
        "shuffle_lambda": 20
      },
      "offload_test_grad": false,
      "offload_train_grad": false,
      "delete_model": true,
      "calculate_infl_in_gpu": true,
      "load_from_grads_path": true,
      "save_to_grads_path": false,
      "grads_path": "./grads_path/",
      "top_k": 1000
    },
    "model": {
      "model_path": "EleutherAI/pythia-2.8b",
      "lora_path": "./datasets/tofu/lora_pythia2p8b_qa",
      "max_length": 512,
      "load_in_4bit": false
    },
    "postprocess": {
        "enable": true,
        "top_n": 1000,
        "list_key": "helpful",
        "infl_key": "helpful_infl",
        "export_dir": "./datasets/tofu/generated_sets"
    }
  }