{
    "data": {
        "train_data_path": "./datasets/tofu/subset.jsonl"
    },
    "influence": {
        "outdir": "output_dir",
        "seed": 42,
        "cal_words_infl": false,
        "save_to_grads_path": true,
        "n_threads": 1,
        "RapidGrad": {
            "enable": true,
            "RapidGrad_K": 65536,
            "shuffle_lambda": 20
        },
        "offload_train_grad": false,
        "skip_test": true,
        "skip_influence": true,
        "grads_path": "./grads_path/"
    },
    "model": {
        "model_path": "EleutherAI/pythia-2.8b",
        "lora_path": "./datasets/tofu/lora_pythia2p8b_qa",
        "max_length": 512,
        "load_in_4bit": false
    },
    "postprocess": {
        "enable": false
    }
}
